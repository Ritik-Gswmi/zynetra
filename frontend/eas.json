{
  "cli": {
    "version": ">= 8.0.0"
  },
  "build": {
    "development": {
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3000"
      },
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://zynetra.onrender.com"
      },
      "distribution": "internal"
    },
    "apk": {
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://zynetra.onrender.com"
      },
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://zynetra.onrender.com"
      }
    }
  }
}
