{
  "expo": {
    "name": "Zynetra",
    "slug": "Zynetra",
    "version": "1.0.0",
    "scheme": "aimicro",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/app-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.zynetra.app",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "android": {
      "package": "com.zynetra.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-notifications",
      "expo-video"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "621f64da-e943-4cfa-b9e9-3679141dff5a"
      }
    }
  }
}
