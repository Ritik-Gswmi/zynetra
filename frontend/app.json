{
  "expo": {
    "name": "Zynetra",
    "slug": "Zynetra",
    "version": "1.0.0",
    "scheme": "aimicro",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/app-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.zynetra.app",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "android": {
      "package": "com.zynetra.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "androidNavigationBar": {
      "enforceContrast": false
    },
    "plugins": [
      "expo-notifications",
      "expo-video"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "ritik699",
    "extra": {
      "eas": {
        "projectId": "d19d98fc-bfd2-43f2-9cfc-aeb85835f224"
      }
    }
  }
}
